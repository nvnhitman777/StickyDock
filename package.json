{
  "name": "stickydock",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "node scripts/build.mjs --msi",
    "dev:ui": "vite",
    "build:ui": "vite build",
    "lint": "eslint --ext .js,.mjs,.ts,.tsx scripts src/renderer/src eslint.config.js --ignore-pattern build/** --ignore-pattern dist/** --ignore-pattern out/** --ignore-pattern .cache/** --ignore-pattern node_modules/** --ignore-pattern wailsjs/**",
    "format": "prettier . --check",
    "format:write": "prettier . --write",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@azure/msal-browser": "^3.18.0",
    "@tiptap/core": "^3.7.0",
    "@tiptap/extension-bubble-menu": "^3.7.0",
    "@tiptap/extension-highlight": "^3.7.0",
    "@tiptap/extension-image": "^3.7.0",
    "@tiptap/extension-link": "^3.7.0",
    "@tiptap/extension-placeholder": "^3.7.0",
    "@tiptap/extension-task-item": "^3.7.0",
    "@tiptap/extension-task-list": "^3.7.0",
    "@tiptap/extension-underline": "^3.7.0",
    "@tiptap/extension-table": "^3.7.0",
    "@tiptap/extension-table-cell": "^3.7.0",
    "@tiptap/extension-table-header": "^3.7.0",
    "@tiptap/extension-table-row": "^3.7.0",
    "@tiptap/markdown": "^3.7.0",
    "@tiptap/react": "^3.7.0",
    "@tiptap/starter-kit": "^3.7.0",
    "framer-motion": "^12.23.12",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "shiki": "^4.2.0",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@tailwindcss/vite": "^4.1.11",
    "@types/node": "^24.1.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}

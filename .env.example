# StickyDock Configuration

# OneDrive Backup
# ===============
# 
# NO SETUP REQUIRED FOR END USERS!
# 
# Just click "Connect to OneDrive" in Settings → Backup
# and sign in with your Microsoft account. Done!
#
# Your database backups will be saved to your OneDrive automatically.
#
# Optional: Use your own Azure app (advanced users/developers only)
# Register an app at https://portal.azure.com and paste the Client ID below
# Leave empty to use the built-in StickyDock app

VITE_AZURE_CLIENT_ID=


